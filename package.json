{
  "name": "adrastea",
  "private": true,
  "version": "0.11.7",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && wrangler dev",
    "build:serve": "npm run build && npm run preview",
    "dev:local": "bash scripts/dev-local.sh",
    "init:local": "bash scripts/init-local.sh",
    "clean:dev": "rm -rf node_modules/.vite && npm run dev",
    "db:reset": "npx supabase db reset && rm -rf worker/.wrangler/state/v3/r2 worker/.wrangler/state/v3/d1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:update": "npx playwright test --update-snapshots",
    "worker:dev": "cd worker && npx wrangler dev --local --persist-to .wrangler/state",
    "worker:deploy": "cd worker && npx wrangler deploy",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@jsquash/webp": "^1.5.0",
    "@milkdown/core": "^7.19.0",
    "@milkdown/ctx": "^7.19.0",
    "@milkdown/preset-commonmark": "^7.19.0",
    "@milkdown/react": "^7.19.0",
    "@supabase/supabase-js": "^2.100.0",
    "@types/react-pdf": "^6.2.0",
    "bcdice": "^4.9.0",
    "dockview": "^5.1.0",
    "file-saver": "^2.0.5",
    "idb": "^8.0.3",
    "konva": "^10.2.0",
    "lucide-react": "^0.576.0",
    "pdfjs-dist": "^3.11.174",
    "react": "^19.1.0",
    "react-advanced-cropper": "^0.20.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-konva": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.0",
    "react-youtube": "^10.1.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.1",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^4.6.0",
    "ansi-regex": "^6.2.2",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.3.1",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.0",
    "wrangler": "^4.77.0"
  }
}
